# PostgreSQL
DATABASE_URL="postgresql://vibcodehub:REDACTED_DB_PASSWORD!@127.0.0.1:5432/vibcodehub?schema=public"

# Keycloak
KEYCLOAK_URL=https://sso.example.com
KEYCLOAK_REALM=vibcodehub
KEYCLOAK_CLIENT_ID=vibcodehub-frontend
KEYCLOAK_BACKEND_CLIENT_ID=vibcodehub-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=<backend-client-secret>

# GitLab
GITLAB_URL=https://git.example.com
GITLAB_API_TOKEN=<your-gitlab-api-token>
GITLAB_WEBHOOK_SECRET=<webhook-secret>

# Ollama (lokal)
OLLAMA_URL=http://127.0.0.1:11434

# LLM API Keys (Cloud)
ANTHROPIC_API_KEY=<your-key>
OPENAI_API_KEY=<your-key>
GOOGLE_AI_API_KEY=<your-key>

# App
APP_URL=https://hub.example.com
API_PORT=3100
FRONTEND_PORT=4200
