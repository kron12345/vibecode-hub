{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "mcp__angular__*",
      "mcp__prisma__*",
      "mcp__context7__*",
      "WebSearch"
    ]
  },
  "mcpServers": {
    "angular": {
      "command": "angular-mcp-server",
      "args": [],
      "type": "stdio"
    },
    "prisma": {
      "command": "npx",
      "args": [
        "prisma",
        "mcp",
        "--schema",
        "./backend/prisma/schema.prisma"
      ],
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "type": "stdio"
    }
  }
}
