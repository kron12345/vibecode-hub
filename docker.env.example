# VibCode Hub — Docker Compose Environment
# Copy to .env (at project root) and adjust values for your setup.

# Database
DB_PASSWORD=vibcodehub-dev
DB_PORT=5432

# Keycloak
KEYCLOAK_PORT=8081
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# GitLab (optional — remove gitlab service if using external instance)
GITLAB_PORT=8929

# Backend API
API_PORT=3100

# Frontend
FRONTEND_PORT=4200
API_URL=http://localhost:3100/api
KEYCLOAK_URL=http://localhost:8081
