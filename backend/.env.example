# VibCode Hub — Environment Configuration
# Only startup essentials are needed here.
# All other settings (GitLab, LLM, CORS, etc.) are managed via the Settings UI.

DATABASE_URL="postgresql://vibcodehub:YOUR_PASSWORD@127.0.0.1:5432/vibcodehub?schema=public"

KEYCLOAK_URL=https://your-keycloak.example.com
KEYCLOAK_REALM=vibcodehub
KEYCLOAK_CLIENT_ID=vibcodehub-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret

PORT=3100
